{
    # Use FrankenPHP for PHP processing
    frankenphp
}

{$PORT:80}

root * /app/public

# Logs
log

# API routes - rewrite to index.php
@api {
    path /api/*
}
rewrite @api /index.php

# Admin routes - serve files, fallback to index.html
@admin {
    path /admin/*
}
route @admin {
    try_files {path} {path}/ /admin/index.html
}

# All other requests - try files, fallback to index.php
route {
    try_files {path} {path}/ /index.php?{query}
}

# PHP processing via FrankenPHP
php {
    resolve_root_symlink
}

# Static file server
file_server
